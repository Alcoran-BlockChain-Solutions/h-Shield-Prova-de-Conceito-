# HarvestShield Scripts Configuration

# Supabase Edge Functions URL (without trailing slash)
SUPABASE_URL=https://your-project.supabase.co/functions/v1

# Supabase anon/public key
SUPABASE_ANON_KEY=your-anon-key

# Device configuration (for simulate_esp32.py)
DEVICE_ID=esp32-farm-001
PRIVATE_KEY_PATH=../keys/esp32-farm-001.key

# Simulator settings
INTERVAL_SECONDS=5
POW_DIFFICULTY=3
