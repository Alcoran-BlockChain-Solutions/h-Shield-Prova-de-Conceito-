# Stellar Configuration
# As variáveis do Supabase (URL, ANON_KEY, SERVICE_ROLE_KEY) são injetadas automaticamente nas Edge Functions

# Chave secreta da conta Stellar (obrigatória)
STELLAR_SECRET_KEY=your-stellar-secret-key

# Rede Stellar: "testnet" ou "mainnet" (padrão: testnet)
# - testnet: https://horizon-testnet.stellar.org (desenvolvimento/testes)
# - mainnet: https://horizon.stellar.org (produção)
STELLAR_NETWORK=testnet
